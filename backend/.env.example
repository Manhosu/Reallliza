PORT=3333
NODE_ENV=development

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Auth
JWT_SECRET=change-me-in-production

# CORS — comma-separated list of allowed origins (include Garantias if cross-origin)
# e.g. http://localhost:3000,https://garantias.reallliza.com.br
CORS_ORIGIN=http://localhost:3000

# ============================================================
# External integration (system-to-system)
# ============================================================
# Base URL of the web dashboard — used to build tracking_url in webhook payloads
WEB_BASE_URL=https://reallliza-web.vercel.app

# Secret used to sign outgoing webhooks (HMAC-SHA256).
# Generate with: openssl rand -hex 32
WEBHOOK_SIGNING_SECRET=replace-with-openssl-rand-hex-32

# UUID of the "system" profile used as created_by for OSs created via integration.
# Insert a profile row (see database/migrations/007_external_integration.sql seed block)
# and put its UUID here.
EXTERNAL_INTEGRATION_USER_ID=00000000-0000-0000-0000-000000000001
